{
  "name": "wcag-explorer",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "db:migrate": "bun run packages/db/src/migrate.ts",
    "db:seed": "bun run packages/db/src/seed.ts",
    "dev": "bun run kill-ports && bun run dev:api & bun run dev:web",
    "dev:api": "cd apps/api && bun run dev",
    "dev:web": "cd apps/web && bun run dev",
    "kill-ports": "lsof -ti:8787,5173 | xargs kill -9 2>/dev/null || true",
    "build": "cd apps/web && bun run build",
    "lint": "cd apps/web && bun run lint",
    "typecheck": "cd apps/web && bun run typecheck",
    "test": "bun test packages/db/src/client.test.ts",
    "test:web": "cd apps/web && bun run test",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@playwright/test": "^1.57.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "cheerio": "^1.1.2",
    "husky": "^9.1.7",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.67.1",
    "@fortawesome/free-regular-svg-icons": "^7.1.0",
    "i18next": "^25.6.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "react-i18next": "^16.3.5"
  }
}
