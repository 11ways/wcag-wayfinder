{
  "metadata": {
    "wcag_version": "2.1",
    "language": "zh",
    "language_native": "简体中文",
    "authorization_type": "authorized",
    "translator": "Zhejiang University",
    "source_url": "https://www.w3.org/Translations/WCAG21-zh/",
    "fetch_date": "2025-11-25",
    "translation_date": "11 March 2019"
  },
  "principles": [
    {
      "id": "perceivable",
      "num": "1",
      "handle": "可感知性 §",
      "title": "信息和用户界面组件必须以可感知的方式呈现给用户。",
      "versions": [
        "2.0",
        "2.1",
        "2.2"
      ],
      "guidelines": [
        {
          "id": "text-alternatives",
          "num": "1.1",
          "handle": "准则 1.1 替代文本§",
          "title": "为所有非文本内容提供替代文本，使其可以转化为人们需要的其他形式，如大字体印刷，盲文，语音，符号或更简单的语言。",
          "versions": [
            "2.0",
            "2.1",
            "2.2"
          ],
          "successcriteria": [
            {
              "id": "non-text-content",
              "num": "1.1.1",
              "handle": "成功标准 1.1.1 非文本内容§",
              "title": "为所有呈现给用户的非文本内容都提供相同目的替代文本以下情况例外：",
              "level": "A",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ],
              "details": [
                {
                  "type": "ulist",
                  "items": [
                    {
                      "handle": "控件，输入",
                      "text": "如果非文本内容是一个控件或接受用户输入，则应有一个描述其目的名称。(请参阅成功标准 4.1.2以了解关于控件和接受用户输入的内容的额外要求)"
                    },
                    {
                      "handle": "时基媒体",
                      "text": "如果非文本内容是时基媒体，这时替代文本至少要提供非文本内容的描述标识。 (请参阅准则 1.2以了解关于媒体的额外要求)"
                    },
                    {
                      "handle": "测试",
                      "text": "如果非文本内容是以一个以文本呈现会失效的测试或练习, 则替代文本至少要提供非文本内容的描述标识。"
                    },
                    {
                      "handle": "感官",
                      "text": "如果非文本内容的主要目的是创建一种特殊感官体验, 则替代文本至少要提供非文本内容的描述标识。"
                    },
                    {
                      "handle": "验证码",
                      "text": "如果非文本内容的目的是为了确认内容正在被一个人访问，而不是计算机访问，则要提供识别和描述非文本内容目的的替代文本，并提供适应针对不同类型感官知觉的输出模型的验证码替代方式， 以适应不同的残障人群。"
                    },
                    {
                      "handle": "装饰，格式，不可见",
                      "text": "如果非文本内容是纯粹的装饰, 或只用于视觉格式、或不呈现给用户，则应以辅助技术可忽略的方式进行实现。"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "time-based-media",
          "num": "1.2",
          "handle": "准则 1.2 时基媒体§",
          "title": "为时基媒体提供替代。",
          "versions": [
            "2.0",
            "2.1",
            "2.2"
          ],
          "successcriteria": [
            {
              "id": "audio-only-and-video-only-prerecorded",
              "num": "1.2.1",
              "handle": "成功标准 1.2.1 纯音频和纯视频（预录）§",
              "title": "对于预录的，纯音频和预录的纯视频, 以下情况为真，除非音频或视频就是文本的替代媒体并已明确标记:",
              "level": "A",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ],
              "details": [
                {
                  "type": "ulist",
                  "items": [
                    {
                      "handle": "预录的纯音频",
                      "text": "对于预录的纯音频内容，给出时基媒体的替代以呈现等同信息。"
                    },
                    {
                      "handle": "预录的纯视频",
                      "text": "对于预录的纯视频内容，给出时基媒体的替代，或者给出音轨，以呈现等同信息。"
                    }
                  ]
                }
              ]
            },
            {
              "id": "captions-prerecorded",
              "num": "1.2.2",
              "handle": "成功标准 1.2.2 字幕（预录）§",
              "title": "所有预录的音频内容，要提供同步媒体的字幕, 除非媒体就是文本的替代媒体并已明确标记。",
              "level": "A",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ]
            },
            {
              "id": "audio-description-or-media-alternative-prerecorded",
              "num": "1.2.3",
              "handle": "成功标准 1.2.3 音频描述或媒体替代（预录）§",
              "title": "要为同步媒体提供时基媒体的替代或预录的视频内容的音频描述 ，除非媒体就是文本的替代媒体并已明确标记。",
              "level": "A",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ]
            },
            {
              "id": "captions-live",
              "num": "1.2.4",
              "handle": "成功标准 1.2.4 字幕（直播）§",
              "title": "为所有直播的音频内容，在同步媒体中提供字幕",
              "level": "AA",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ]
            },
            {
              "id": "audio-description-prerecorded",
              "num": "1.2.5",
              "handle": "成功标准 1.2.5 音频描述（预录）§",
              "title": "为所有预录的视频内容，在同步媒体中提供音频描述",
              "level": "AA",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ]
            },
            {
              "id": "sign-language-prerecorded",
              "num": "1.2.6",
              "handle": "成功标准 1.2.6 手语（预录）§",
              "title": "要为同步媒体里所有预录的音频内容提供手语翻译。",
              "level": "AAA",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ]
            },
            {
              "id": "extended-audio-description-prerecorded",
              "num": "1.2.7",
              "handle": "成功标准 1.2.7  扩展音频描述（预录）§",
              "title": "前景音频描述不足以传达视频意思时，可通过暂停，把同步媒体里所有预录的视频内容扩展音频描述 提供出来。",
              "level": "AAA",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ]
            },
            {
              "id": "media-alternative-prerecorded",
              "num": "1.2.8",
              "handle": "成功标准 1.2.8 替代媒体（预录）§",
              "title": "为所有预录的同步媒体和所有预录的纯视频媒体提供时基媒体的替代 。",
              "level": "AAA",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ]
            },
            {
              "id": "audio-only-live",
              "num": "1.2.9",
              "handle": "成功标准 1.2.9 纯音频（直播）§",
              "title": "要为现场直播的纯音频内容提供时基媒体的替代，以呈现等同信息。",
              "level": "AAA",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ]
            }
          ]
        },
        {
          "id": "adaptable",
          "num": "1.3",
          "handle": "准则 1.3 适应性§",
          "title": "创建可用不同方式呈现的内容（例如简单的布局），而不会丢失信息或结构。",
          "versions": [
            "2.0",
            "2.1",
            "2.2"
          ],
          "successcriteria": [
            {
              "id": "info-and-relationships",
              "num": "1.3.1",
              "handle": "成功标准 1.3.1 信息和关系§",
              "title": "通过呈现传达的信息、结构、和关系，可以编程式确定或在文本中得到。",
              "level": "A",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ]
            },
            {
              "id": "meaningful-sequence",
              "num": "1.3.2",
              "handle": "成功标准 1.3.2 有含义的顺序§",
              "title": "当呈现出来的内容其顺序影响其含义，可以通过编程式确定其正确的阅读顺序。",
              "level": "A",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ]
            },
            {
              "id": "sensory-characteristics",
              "num": "1.3.3",
              "handle": "成功标准 1.3.3 感官特性§",
              "title": "用于理解内容和操作内容的指示，应该不完全依赖于组件的感官特性，如形状、大小、视觉位置、方向、或声音。",
              "level": "A",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ],
              "details": [
                {
                  "type": "note",
                  "text": "注：请参考颜色相关的要求，参见准则 1.4."
                }
              ]
            },
            {
              "id": "orientation",
              "num": "1.3.4",
              "handle": "成功标准 1.3.4 定位§",
              "title": "不应该将内容的视图和操作限定为单一的显示方向，例如纵向或横向，除非使用特定的显示方向是必要的。",
              "level": "AA",
              "versions": [
                "2.1",
                "2.2"
              ],
              "details": [
                {
                  "type": "note",
                  "text": "注意特定显示方向可能必要的示例是银行支票，钢琴应用，投影仪或电视的幻灯片，或二进制显示方向不适用的虚拟现实内容。"
                }
              ]
            },
            {
              "id": "identify-input-purpose",
              "num": "1.3.5",
              "handle": "成功标准 1.3.5 明确输入目的§",
              "title": "用于收集用户信息的每个输入框的目的可以在以下情况下编程式确定：",
              "level": "AA",
              "versions": [
                "2.1",
                "2.2"
              ]
            },
            {
              "id": "identify-purpose",
              "num": "1.3.6",
              "handle": "成功标准 1.3.6 明确目的§",
              "title": "在使用标记语言实现的内容中，用户界面组件、图标及区域的用途可以编程式确定。",
              "level": "AAA",
              "versions": [
                "2.1",
                "2.2"
              ]
            }
          ]
        },
        {
          "id": "distinguishable",
          "num": "1.4",
          "handle": "准则 1.4 可辨别性§",
          "title": "使用户更容易看到和听到内容，包括把背景和前景分开。",
          "versions": [
            "2.0",
            "2.1",
            "2.2"
          ],
          "successcriteria": [
            {
              "id": "use-of-color",
              "num": "1.4.1",
              "handle": "准则 1.4.1 颜色用途§",
              "title": "颜色并不是作为传达信息、表明动作、提示响应或区分视觉元素的唯一视觉手段。",
              "level": "A",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ],
              "details": [
                {
                  "type": "note",
                  "text": "注：此成功标准专门解决颜色感知的问题。准则 1.3已覆盖其他形式的感知，包括编程式访问颜色和其他视觉呈现的编码。"
                }
              ]
            },
            {
              "id": "audio-control",
              "num": "1.4.2",
              "handle": "成功标准 1.4.2 音频控制§",
              "title": "如果网页音频自动播放超过3秒钟，提供一个机制用以暂停或停止音频，或者控制独立于全局系统音量的音频音量。",
              "level": "A",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ],
              "details": [
                {
                  "type": "note",
                  "text": "注：由于任何不符合此成功标准的内容可干扰用户使用整个页面的能力，所有网页内容（不论是否符合其他成功标准）必须符合这项成功标准。参见一致性要求5：不干扰。"
                }
              ]
            },
            {
              "id": "contrast-minimum",
              "num": "1.4.3",
              "handle": "成功标准 1.4.3 对比度（最小）§",
              "title": "文本视觉呈现以及文本图像至少要有4.5:1的对比度, 以下部分除外：",
              "level": "AA",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ],
              "details": [
                {
                  "type": "ulist",
                  "items": [
                    {
                      "handle": "大文本",
                      "text": "大号文本以及大文本图像至少有3:1的对比度;"
                    },
                    {
                      "handle": "附属内容",
                      "text": "文本或文本图像是未激活的用户界面组件部分, 或者只是一个纯粹的装饰,或者对任何人不可见，或者只是包含其他重要可视内容的图片一部分，此文本或文本图像没有对比要求。"
                    },
                    {
                      "handle": "商标",
                      "text": "文本作为标志或品牌名称的一部分，没有最低对比要求。"
                    }
                  ]
                }
              ]
            },
            {
              "id": "resize-text",
              "num": "1.4.4",
              "handle": "成功标准 1.4.4 调整文本§",
              "title": "除了字幕和文本图像外，文本大小不需要辅助技术就可以放大至200%，且没有内容或功能损失。",
              "level": "AA",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ]
            },
            {
              "id": "images-of-text",
              "num": "1.4.5",
              "handle": "成功标准 1.4.5 文本图像§",
              "title": "如果正在使用的技术可以达到视觉效果，应使用文本传达信息而不用文本图像，以下部分除外：",
              "level": "AA",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ],
              "details": [
                {
                  "type": "ulist",
                  "items": [
                    {
                      "handle": "定制",
                      "text": "文本图像可根据用户要求进行视觉定制；"
                    },
                    {
                      "handle": "必需",
                      "text": "文本的特殊呈现对要传达的信息是必需的。"
                    }
                  ]
                },
                {
                  "type": "note",
                  "text": "注：商标（文本作为标志或品牌名称的一部分）被认为是必需的。"
                }
              ]
            },
            {
              "id": "contrast-enhanced",
              "num": "1.4.6",
              "handle": "成功标准 1.4.6 对比度（加强）§",
              "title": "文本视觉呈现以及文本图像至少有 7:1的对比度以下部分除外：",
              "level": "AAA",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ],
              "details": [
                {
                  "type": "ulist",
                  "items": [
                    {
                      "handle": "大文本",
                      "text": "大号文本以及大文本图像至少有 4.5:1的对比度;"
                    },
                    {
                      "handle": "附属内容",
                      "text": "文本或文本图像是未激活的用户界面组件部分, 或者只是一个纯粹的装饰, 或者对任何人不可见，或者只是包含其他重要可视内容的图片一部分，此文本或文本图像没有对比要求。"
                    },
                    {
                      "handle": "商标",
                      "text": "文本作为标志或品牌名称的一部分，没有最低对比要求。"
                    }
                  ]
                }
              ]
            },
            {
              "id": "low-or-no-background-audio",
              "num": "1.4.7",
              "handle": "成功标准 1.4.7 低背景音或无背景音§",
              "title": "对于预录的纯音频内容， (1) 前景音频主要包含说话内容, (2) 不是音频验证码或音频标志，以及(3) 不发声，主要用音乐表达，如唱歌或说唱，以下部分至少有一为真:",
              "level": "AAA",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ],
              "details": [
                {
                  "type": "ulist",
                  "items": [
                    {
                      "handle": "无背景",
                      "text": "音频不包含背景声音。"
                    },
                    {
                      "handle": "关闭",
                      "text": "背景声音可以被关闭。"
                    },
                    {
                      "handle": "20分贝",
                      "text": "背景声音至少比前景说话内容低20分贝，持续仅一两秒的偶发性声音除外。"
                    }
                  ]
                },
                {
                  "type": "note",
                  "text": "注：根据 “分贝”的定义，满足这一要求的背景声音将比前景说话内容大约安静4倍。"
                }
              ]
            },
            {
              "id": "visual-presentation",
              "num": "1.4.8",
              "handle": "成功标准 1.4.8 视觉呈现§",
              "title": "对于文本块的视觉呈现，提供一个机制以实现以下目标:",
              "level": "AAA",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ]
            },
            {
              "id": "images-of-text-no-exception",
              "num": "1.4.9",
              "handle": "成功标准 1.4.9 文本图像（没有例外）§",
              "title": "文本图像只能用于纯粹的装饰或此文本的特殊呈现对要传达的信息是必需。",
              "level": "AAA",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ],
              "details": [
                {
                  "type": "note",
                  "text": "注：商标（文本是一个标志或品牌名称的一部分）被认为是必需的。"
                }
              ]
            },
            {
              "id": "reflow",
              "num": "1.4.10",
              "handle": "成功标准 1.4.10 反复滚动§",
              "title": "内容可以在不丢失信息或功能，且在下面两种规格里无需滑动滚动条的情况下呈现：",
              "level": "AA",
              "versions": [
                "2.1",
                "2.2"
              ],
              "details": [
                {
                  "type": "note",
                  "text": "注意320个CSS像素相当于起始窗口宽度为1280CSS像素在400%放大后的宽度。对于设计为水平滚动的Web内容（例如，使用垂直文本），256像素相当于起始窗口为1024像素在400%放大后的高度。"
                },
                {
                  "type": "note",
                  "text": "注意需要二维布局的内容的示例是图像，地图，图表，视频，游戏，演示文稿，数据表和界面，其中在操纵内容时必须保持工具栏在视图中。"
                }
              ]
            },
            {
              "id": "non-text-contrast",
              "num": "1.4.11",
              "handle": "成功标准 1.4.11 非文本对比§",
              "title": "以下内容在视觉呈现时，与相邻颜色的对比度至少为3：1：",
              "level": "AA",
              "versions": [
                "2.1",
                "2.2"
              ],
              "details": [
                {
                  "type": "ulist",
                  "items": [
                    {
                      "handle": "用户界面组件",
                      "text": "识别用户界面组件和状态所需的可视化信息，除非活动组件或组件的外观由用户代理确定且未被作者修改;"
                    },
                    {
                      "handle": "图形图像",
                      "text": "理解内容所必需的图形部分，除非图形的某种特定呈现对所传达的信息至关重要。"
                    }
                  ]
                }
              ]
            },
            {
              "id": "text-spacing",
              "num": "1.4.12",
              "handle": "成功标准 1.4.12 文本间距§",
              "title": "在使用支持以下文本样式属性的标记语言实现的内容中，通过设置以下所有内容并且不更改其他样式属性，不会丢失任何内容或功能：",
              "level": "AA",
              "versions": [
