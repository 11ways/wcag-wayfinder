    {
      "id": "operable",
      "num": "2",
      "handle": "可操作性 §",
      "title": "用户界面组件和导航必须可操作。",
      "versions": [
        "2.0",
        "2.1",
        "2.2"
      ],
      "guidelines": [
        {
          "id": "keyboard-accessible",
          "num": "2.1",
          "handle": "准则 2.1 键盘可访问§",
          "title": "使所有功能都能通过键盘来操作。",
          "versions": [
            "2.0",
            "2.1",
            "2.2"
          ],
          "successcriteria": [
            {
              "id": "keyboard",
              "num": "2.1.1",
              "handle": "准则 2.1.1 键盘§",
              "title": "内容的所有功能都可以通过键盘接口实现操作并且没有对每次键击做特定时限要求。除非底层功能是依赖用户的移动路径并且不做为端点的输入方法。",
              "level": "A",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ]
            },
            {
              "id": "no-keyboard-trap",
              "num": "2.1.2",
              "handle": "成功标准 2.1.2 无键盘陷阱§",
              "title": "如果可使用键盘接口能将焦点到移动到某网页组件上，那么可以只使用键盘接口操作也可以将焦点从当前组件移开，如果需要未修改的方向键或Tab键或其它标准退出方式以外的操作，要告知用户离开焦点的方法。",
              "level": "A",
              "versions": [
                "2.0",
                "2.1",
                "2.2"
              ]
            },
